# ─────────────────────────────────────────────────────────────────
# Oracle Fusion Cloud ERP — Connection
# ─────────────────────────────────────────────────────────────────

# Base URL of your Oracle Fusion Cloud instance (no trailing slash)
# Example: https://efss-abc123-fa.oracledemos.com
ORACLE_HOST=https://your-instance.fa.us2.oraclecloud.com

# Basic auth credentials (used as fallback if OAuth is unavailable)
ORACLE_USERNAME=gl_integration_user
ORACLE_PASSWORD=SomeStrongPassword!

# ─────────────────────────────────────────────────────────────────
# Oracle Fusion Cloud — OAuth 2.0 (preferred over basic auth)
# Register a Confidential Application in IDCS / OCI IAM Domain
# Grant type: Client Credentials
# ─────────────────────────────────────────────────────────────────
ORACLE_CLIENT_ID=abc123def456ghi789jkl000
ORACLE_CLIENT_SECRET=SomeOAuthSecret-xyz987

# Token endpoint — typically your IDCS stripe URL
# Example: https://idcs-abc123.identity.oraclecloud.com/oauth2/v1/token
ORACLE_TOKEN_URL=https://idcs-your-stripe.identity.oraclecloud.com/oauth2/v1/token

# ─────────────────────────────────────────────────────────────────
# Oracle GL Configuration
# ─────────────────────────────────────────────────────────────────

# GL_LEDGERS.LEDGER_ID for the primary ledger to reconcile
ORACLE_LEDGER_ID=1001

# Accounting period name matching GL_PERIODS.PERIOD_NAME
# Format matches Oracle period naming: Mon-YY (e.g. Jan-25)
ORACLE_PERIOD_NAME=Jan-25

# ─────────────────────────────────────────────────────────────────
# LLM Provider Selection
# ─────────────────────────────────────────────────────────────────

# Choose which LLM provider to use: claude | openai
AGENT_PROVIDER=claude

# ─────────────────────────────────────────────────────────────────
# Anthropic Claude
# ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Model to use — claude-opus-4-5 recommended for complex reconciliations
CLAUDE_MODEL=claude-opus-4-5

# ─────────────────────────────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-key-here

# gpt-4o recommended; gpt-4o-mini for cost-sensitive high-volume runs
OPENAI_MODEL=gpt-4o

# ─────────────────────────────────────────────────────────────────
# Agent Behavior
# ─────────────────────────────────────────────────────────────────

# Maximum tool-calling rounds before the agent stops (prevents runaway loops)
MAX_TOOL_ROUNDS=20

# LLM temperature (0.0 = deterministic, preferred for accounting tasks)
AGENT_TEMPERATURE=0.0

# ─────────────────────────────────────────────────────────────────
# Notifications
# ─────────────────────────────────────────────────────────────────

# Email address of GL Controller / approver for corrective journal sign-off
APPROVER_EMAIL=gl-controller@yourcompany.com

# SMTP relay for sending approval request emails
SMTP_HOST=smtp.yourcompany.com
SMTP_PORT=587
SMTP_USERNAME=notifications@yourcompany.com
SMTP_PASSWORD=SmtpPassword!
SMTP_USE_TLS=true

# ─────────────────────────────────────────────────────────────────
# Output Paths
# ─────────────────────────────────────────────────────────────────

# Directory where FBDI files and HTML reports will be written
OUTPUT_DIR=output
